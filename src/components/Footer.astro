---
const year = new Date().getFullYear();
const waHref = 'https://wa.me/524422184424';
---

<footer class="mt-24 border-t border-ink-300/40 bg-surface">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 grid grid-cols-1 md:grid-cols-3 gap-10">
    <div>
      <div class="flex items-center gap-2 mb-3">
        <img src="/logo.png" alt="SimAcademy" class="h-8 w-auto" width="32" height="32" />
        <span class="font-display text-lg font-semibold text-ink-900">SimAcademy</span>
      </div>
      <p class="text-sm text-ink-500 mb-4">
        Educación en simulación clínica para LATAM.
      </p>
      <ul class="space-y-1 text-sm">
        <li><a href="https://info.simacademy.lat" class="text-ink-700 hover:text-brand-purple">info.simacademy.lat</a></li>
        <li><a href="https://blog.simacademy.lat" class="text-ink-700 hover:text-brand-purple">blog.simacademy.lat</a></li>
        <li><a href="https://moodle.simacademy.lat" class="text-ink-700 hover:text-brand-purple">moodle.simacademy.lat</a></li>
        <li><a href="https://kanban.simacademy.lat" class="text-ink-700 hover:text-brand-purple">kanban.simacademy.lat</a></li>
      </ul>
    </div>

    <div>
      <h3 class="font-display text-base font-semibold text-ink-900 mb-3">Recursos</h3>
      <ul class="space-y-1 text-sm">
        <li><a href="/cancelacion" class="text-ink-700 hover:text-brand-purple">Política de cancelación</a></li>
        <li><a href="/conducta" class="text-ink-700 hover:text-brand-purple">Código de conducta</a></li>
        <li><a href="/etica" class="text-ink-700 hover:text-brand-purple">Ética y privacidad</a></li>
      </ul>
    </div>

    <div>
      <h3 class="font-display text-base font-semibold text-ink-900 mb-3">Contacto</h3>
      <ul class="space-y-2 text-sm text-ink-700">
        <li>
          <a href={waHref} target="_blank" rel="noopener" class="hover:text-brand-purple">
            WhatsApp: +52 442 218 4424
          </a>
        </li>
        <li>
          <a href="mailto:hola@simacademy.lat" class="hover:text-brand-purple">hola@simacademy.lat</a>
        </li>
        <li class="text-ink-500">Querétaro, México</li>
      </ul>
      <div class="mt-4 flex items-center gap-4">
        <a
          href="https://www.instagram.com/simacademy.lat"
          target="_blank"
          rel="noopener"
          class="text-ink-500 hover:text-brand-purple text-sm"
          aria-label="Instagram"
        >
          @simacademy.lat
        </a>
        <a
          href="https://www.linkedin.com/company/simacademy-latam"
          target="_blank"
          rel="noopener"
          class="text-ink-500 hover:text-brand-purple text-sm"
          aria-label="LinkedIn"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-ink-300/40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4 text-xs text-ink-500 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p>© {year} SimAcademy. Todos los derechos reservados.</p>
      <p>Hecho con cariño en LATAM.</p>
    </div>
  </div>
</footer>
