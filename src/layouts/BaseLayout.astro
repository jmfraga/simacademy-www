---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { buildOgImageUrl, organizationLd, type OgType } from '../utils/seo';

interface Props {
  title?: string;
  description?: string;
  /** Override OG image (defaults to /og/<slug>.png based on pathname). */
  ogImage?: string;
  /** og:type — "website" by default, "article" for resource subpages. */
  ogType?: OgType;
  /** Extra JSON-LD blocks (objects), merged with the global Organization LD. */
  structuredData?: Record<string, unknown>[];
}

const {
  title = 'SimAcademy — Educación en simulación clínica para LATAM',
  description = 'SimAcademy: formación basada en simulación, debriefing y educación médica continua para profesionales de la salud en Latinoamérica.',
  ogImage,
  ogType = 'website',
  structuredData = [],
} = Astro.props;

const siteUrl = Astro.site!;
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = buildOgImageUrl(Astro.url.pathname, siteUrl, ogImage);

const jsonLdBlocks = [organizationLd(siteUrl), ...structuredData];
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#6B21A8" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/logo.png`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/logo.png`} />
    <link rel="canonical" href={canonical} />

    <link rel="preconnect" href="https://apps.clientify.net" />
    <link rel="preconnect" href="https://api.clientify.net" />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="SimAcademy" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="es_MX" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <title>{title}</title>

    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:bg-brand-purple focus:text-white focus:px-3 focus:py-2 focus:rounded">
      Saltar al contenido
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <!-- Clientify WhatsApp widget compartido SimAcademy -->
    <script is:inline defer src="https://apps.clientify.net/widget-whatsapp2.0/app/assets/index-5yccDyx4.js?id=d2a8fb3d-8cd3-4135-b0b8-92db6c2dca79&path=https://plus.clientify.com"></script>

    <script>
      // Reveal-on-scroll: any element with .reveal gets .in when intersecting.
      function initReveal() {
        if (typeof window === 'undefined') return;
        const prefersReduced = window.matchMedia?.(
          '(prefers-reduced-motion: reduce)'
        ).matches;
        const els = document.querySelectorAll<HTMLElement>('.reveal:not(.in)');
        if (prefersReduced) {
          els.forEach((el) => el.classList.add('in'));
          return;
        }
        const obs = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in');
                obs.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach((el) => obs.observe(el));
      }
      initReveal();
      document.addEventListener('astro:page-load', initReveal);
    </script>
  </body>
</html>
