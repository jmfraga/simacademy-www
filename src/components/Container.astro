---
interface Props {
  variant?: 'narrow' | 'default' | 'wide';
  as?: string;
  class?: string;
}

const { variant = 'default', as = 'div', class: className = '' } = Astro.props;

const maxWidth = {
  narrow: 'max-w-3xl',
  default: 'max-w-6xl',
  wide: 'max-w-7xl',
}[variant];

const Tag = as as any;
---

<Tag class={`${maxWidth} mx-auto px-4 sm:px-6 lg:px-8 ${className}`}>
  <slot />
</Tag>
