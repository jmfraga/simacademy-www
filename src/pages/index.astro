---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import CourseCard from '../components/CourseCard.astro';
import CtaBlock from '../components/CtaBlock.astro';
import StatCounter from '../components/islands/StatCounter.tsx';
import TestimonialCarousel from '../components/islands/TestimonialCarousel.tsx';
import { courseLd } from '../utils/seo';

const cursos = await getCollection('cursos');
const featured = cursos
  .filter((c) => c.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const siteUrl = Astro.site!;
const featuredLd = featured.map((c) =>
  courseLd(
    {
      title: c.data.title,
      description: c.data.description,
      modality: c.data.modality,
      href: c.data.href,
      dates: c.data.dates,
    },
    siteUrl,
  ),
);

const modalityLabel = {
  online: 'En línea',
  presencial: 'Presencial',
  hibrido: 'Híbrido',
};

const testimonials = [
  {
    quote:
      'Finalizo este curso con mis expectativas ampliamente superadas. La práctica de las herramientas guiadas por expertos fue invaluable.',
    author: 'Participante EuSim Nivel 1',
    role: 'Fundación Barceló · Buenos Aires, 2024',
  },
  {
    quote:
      'Es un parte aguas en mi vida profesional. Aprendes haciendo, nada aburrido, muy humano: se aprende metodología, no solo técnicas.',
    author: 'Participante EuSim Nivel 1',
    role: 'Centro de Desarrollo ABC · México, 2025',
  },
  {
    quote:
      'El profesionalismo y la seguridad psicológica que te brindan marcaron una gran diferencia. Agradecidos por su hospitalidad y dedicación.',
    author: 'Participante EuSim Nivel 1',
    role: 'Universidad Barceló · Argentina, 2024',
  },
  {
    quote:
      'Gracias por esta experiencia inolvidable. La tutoría personalizada y el acompañamiento continuo de los docentes hicieron toda la diferencia.',
    author: 'Participante EuSim Nivel 2',
    role: 'SimAcademy · Modalidad virtual, 2025',
  },
  {
    quote:
      'Me encantó la estructura del curso, el ambiente cálido de los instructores y la retroalimentación constante. Excelentes maestros.',
    author: 'Participante EuSim Nivel 1',
    role: 'CITES · Monterrey, 2023',
  },
  {
    quote:
      'La diversidad de opiniones y experiencias, y participar en diferentes roles, me permitió tener distintas perspectivas del mismo aspecto. Excelente curso.',
    author: 'Participante EuSim Nivel 1',
    role: 'Fundación Barceló · Buenos Aires, 2024',
  },
];
---

<BaseLayout
  title="SimAcademy — Educación en simulación clínica para LATAM"
  description="SimAcademy: formación basada en simulación, debriefing estructurado y educación médica continua para profesionales de la salud en Latinoamérica."
  structuredData={featuredLd}
>
  <Hero
    eyebrow="SimAcademy"
    title="Educación en simulación clínica para LATAM."
    subtitle="Formamos a profesionales de la salud a través de simulación, debriefing estructurado y comunidades de práctica."
    ctaPrimary={{ label: 'Ver cursos', href: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/oferta-educativa` }}
    ctaSecondary={{
      label: 'Hablar con un asesor',
      href: 'https://wa.me/524422184424',
    }}
  />

  <section class="reveal py-20 sm:py-28">
    <Container variant="narrow">
      <SectionTitle
        eyebrow="Nuestra filosofía"
        title="Practicar lo difícil, en un lugar seguro."
        align="center"
      />
      <div class="mt-8 space-y-5 text-lg text-ink-700 leading-relaxed text-center max-w-2xl mx-auto">
        <p>
          La medicina se aprende cuidando personas. Pero hay momentos —los más
          difíciles, los más raros, los más definitivos— en los que no hay
          espacio para equivocarse. La simulación clínica existe para esos
          momentos: para que el primer error nunca caiga sobre un paciente real.
        </p>
        <p>
          En SimAcademy diseñamos programas de formación basados en simulación,
          debriefing estructurado y educación continua, con instructores
          certificados y faculty internacional. Trabajamos en español, desde
          LATAM, con estándares globales.
        </p>
      </div>
    </Container>
  </section>

  <section class="reveal bg-[var(--gradient-soft)] py-20 sm:py-24">
    <Container>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10">
        <StatCounter client:visible value={25} label="Años de trayectoria" />
        <StatCounter client:visible value={100000} suffix="+" label="Certificaciones AHA" />
        <StatCounter client:visible value={300} suffix="+" label="Educadores EuSim formados" />
        <StatCounter client:visible value={8} suffix="+" label="Países alcanzados" />
      </div>
    </Container>
  </section>

  <section class="reveal py-20 sm:py-28">
    <Container>
      <div class="flex flex-wrap items-end justify-between gap-6 mb-12">
        <SectionTitle
          eyebrow="Oferta educativa"
          title="Próximos cursos"
          subtitle="Programas presenciales, en línea e híbridos para profesionales de la salud, educadores y centros de simulación."
        />
        <a
          href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/oferta-educativa`}
          class="text-sm font-semibold text-brand-purple inline-flex items-center gap-1 hover:gap-2 transition-all"
        >
          Ver todos
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featured.map((curso) => (
          <CourseCard
            title={curso.data.shortTitle ?? curso.data.title}
            description={curso.data.description}
            modality={modalityLabel[curso.data.modality]}
            dates={curso.data.dates}
            price={curso.data.price}
            slug={curso.id}
            href={curso.data.href}
            image={curso.data.image}
            accent={curso.data.accent}
          />
        ))}
      </div>
    </Container>
  </section>

  <section class="reveal py-20 sm:py-28 bg-surface">
    <Container>
      <SectionTitle
        eyebrow="Voces de la comunidad"
        title="Lo que dicen quienes ya pasaron por aquí."
        align="center"
        class="mx-auto mb-12"
      />
      <TestimonialCarousel client:load items={testimonials} />
    </Container>
  </section>

  <CtaBlock
    variant="purple"
    title="Algo más que un curso."
    description="Únete a la comunidad de educadores en simulación clínica de Latinoamérica. Hablemos de tu próximo proyecto."
    ctaLabel="Hablar con SimAcademy"
    ctaHref="https://wa.me/524422184424"
  />
</BaseLayout>
