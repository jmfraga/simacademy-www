---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="divide-y divide-ink-300/40 rounded-[var(--r-md)] border border-ink-300/40 bg-surface overflow-hidden">
  {items.map((item) => (
    <details class="faq-item group">
      <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none hover:bg-ink-300/10 transition-colors">
        <span class="font-medium text-ink-900 text-base sm:text-lg">
          {item.question}
        </span>
        <svg
          class="faq-chevron flex-none text-brand-purple"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </summary>
      <div class="faq-body">
        <div class="px-5 pb-5 pt-1 text-ink-700 leading-relaxed text-sm sm:text-base">
          {item.answer}
        </div>
      </div>
    </details>
  ))}
</div>

<style>
  /* Hide default disclosure marker across browsers */
  details > summary::-webkit-details-marker { display: none; }
  details > summary { list-style: none; }
</style>
