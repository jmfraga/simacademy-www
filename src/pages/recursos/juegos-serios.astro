---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Hero from '../../components/Hero.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import CtaBlock from '../../components/CtaBlock.astro';
---

<BaseLayout
  title="Juegos serios — Recursos SimAcademy"
  description="Recursos sobre diseño de juegos para la educación clínica, autoría de Rodrigo Rubio Martínez."
>
  <Hero
    eyebrow="Recursos"
    title="Diseño de juegos para educación"
    subtitle="Una colección de materiales sobre cómo los juegos serios pueden complementar la formación de profesionales de la salud."
  />

  <section class="reveal py-20 sm:py-28">
    <Container variant="narrow">
      <SectionTitle title="¿Qué son los juegos serios?" />
      <div class="mt-6 space-y-5 text-lg text-ink-700 leading-relaxed">
        <p>
          Los juegos serios (<em>serious games</em>) son experiencias lúdicas
          diseñadas con un propósito educativo explícito. En el contexto de la
          formación clínica, son una herramienta complementaria a la
          simulación: permiten practicar la toma de decisiones, la
          comunicación de equipo y el razonamiento clínico en un entorno
          motivador y reproducible.
        </p>
        <p>
          A diferencia del entretenimiento puro, los juegos serios se diseñan
          a partir de objetivos de aprendizaje y se evalúan en función de la
          transferencia de competencias a la práctica.
        </p>
        <!-- TODO Phase 7: ampliar con ejemplos concretos de juegos usados en cursos SimAcademy -->
      </div>

      <div class="mt-12 rounded-[var(--r-md)] border border-ink-300/40 bg-surface p-6 sm:p-8">
        <h2 class="font-display text-xl font-semibold text-ink-900 mb-3">
          Documentos disponibles
        </h2>
        <p class="text-sm text-ink-700 mb-5">
          Texto y referencias escritos por <strong>Rodrigo Rubio Martínez</strong>, 2024.
        </p>
        <ul class="space-y-3" role="list">
          <li>
            <a
              href="https://simacademy.emergencias.com.mx/recursos/juegos-serios"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 text-brand-purple font-semibold hover:underline"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              Texto principal y referencias
            </a>
            <!-- TODO Phase 7: reemplazar link al Google Sites por hosting propio (Drive público o PDF en /public) -->
          </li>
        </ul>
      </div>
    </Container>
  </section>

  <CtaBlock
    variant="purple"
    title="¿Quieres aportar un juego serio?"
    description="Si has diseñado o usado un juego serio en formación clínica y quieres compartirlo con la comunidad, hablemos."
    ctaLabel="Escribir por WhatsApp"
    ctaHref="https://wa.me/524422184424"
  />
</BaseLayout>
