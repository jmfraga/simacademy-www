---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  as?: 'h1' | 'h2';
  class?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  align = 'left',
  as = 'h2',
  class: className = '',
} = Astro.props;

const alignClass = align === 'center' ? 'text-center mx-auto' : 'text-left';
const Heading = as;
---

<header class={`${alignClass} max-w-3xl ${className}`}>
  {eyebrow && (
    <p class="text-xs sm:text-sm font-semibold tracking-[0.18em] uppercase text-brand-purple mb-3">
      {eyebrow}
    </p>
  )}
  <Heading
    class={`font-display font-semibold text-ink-900 ${
      as === 'h1'
        ? 'text-4xl sm:text-5xl lg:text-6xl'
        : 'text-3xl sm:text-4xl lg:text-5xl'
    } mb-4`}
  >
    {title}
  </Heading>
  {subtitle && (
    <p class="text-lg text-ink-700 leading-relaxed">
      {subtitle}
    </p>
  )}
</header>
