---
const B = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
const waHref = 'https://wa.me/524422184424';
---

<footer class="mt-24 border-t border-ink-300/40 bg-surface">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
    <!-- Brand + sub-sites -->
    <div>
      <div class="flex items-center gap-2 mb-3">
        <img src={`${B}/logo.png`} alt="" class="h-8 w-auto" width="32" height="32" />
        <span class="font-display text-lg font-semibold text-ink-900">SimAcademy</span>
      </div>
      <p class="text-sm text-ink-500 mb-4">
        Educación en simulación clínica para LATAM.
      </p>
      <ul class="space-y-1.5 text-sm">
        <li><a href="https://info.simacademy.lat" class="text-ink-700 hover:text-brand-purple">info.simacademy.lat</a></li>
        <li><a href="https://blog.simacademy.lat" class="text-ink-700 hover:text-brand-purple">blog.simacademy.lat</a></li>
        <li><a href="https://moodle.simacademy.lat" class="text-ink-700 hover:text-brand-purple">moodle.simacademy.lat</a></li>
        <li><a href="https://kanban.simacademy.lat" class="text-ink-700 hover:text-brand-purple">kanban.simacademy.lat</a></li>
      </ul>
    </div>

    <!-- Recursos -->
    <div>
      <h3 class="font-display text-base font-semibold text-ink-900 mb-3">Recursos</h3>
      <ul class="space-y-1.5 text-sm">
        <li><a href={`${B}/cancelaciones`} class="text-ink-700 hover:text-brand-purple">Política de cancelación</a></li>
        <li><a href={`${B}/pagos`} class="text-ink-700 hover:text-brand-purple">Información de pagos</a></li>
        <li><a href={`${B}/recursos/codigo-de-conducta`} class="text-ink-700 hover:text-brand-purple">Código de conducta</a></li>
        <li><a href={`${B}/recursos/codigo-de-etica`} class="text-ink-700 hover:text-brand-purple">Código de ética</a></li>
        <li><a href={`${B}/contacto`} class="text-ink-700 hover:text-brand-purple">Contacto</a></li>
      </ul>
    </div>

    <!-- Síguenos -->
    <div>
      <h3 class="font-display text-base font-semibold text-ink-900 mb-3">Síguenos</h3>
      <ul class="space-y-1.5 text-sm">
        <li>
          <a href="https://www.instagram.com/simacademy.lat" target="_blank" rel="noopener" class="text-ink-700 hover:text-brand-purple">
            Instagram
          </a>
        </li>
        <li>
          <a href="https://www.linkedin.com/company/simacademy-latam" target="_blank" rel="noopener" class="text-ink-700 hover:text-brand-purple">
            LinkedIn
          </a>
        </li>
        <li>
          <a href={waHref} target="_blank" rel="noopener" class="text-ink-700 hover:text-brand-purple">
            WhatsApp
          </a>
        </li>
        <li>
          <a href="mailto:contacto@simacademy.lat" class="text-ink-700 hover:text-brand-purple">contacto@simacademy.lat</a>
        </li>
      </ul>
    </div>

    <!-- Newsletter (Clientify superform) -->
    <div>
      <h3 class="font-display text-base font-semibold text-ink-900 mb-3">Suscríbete</h3>
      <p class="text-sm text-ink-500 mb-3">
        Recibe novedades sobre cursos, talleres y eventos.
      </p>
      <div data-clientify-newsletter></div>
      <script is:inline data-astro-rerun type="text/javascript" src="https://api.clientify.net/web-marketing/superforms/script/283152.js"></script>
      <p class="text-xs text-ink-500 mt-2">No spam. Cancela cuando quieras.</p>
    </div>
  </div>

  <div class="border-t border-ink-300/40">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4 text-xs text-ink-500 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p>© {year} SimAcademy® — marca registrada. Operado por Asesores en Emergencias y Desastres S de RL de CV.</p>
      <p>Hecho con cariño en LATAM.</p>
    </div>
  </div>
</footer>
