---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Hero from '../components/Hero.astro';
import CtaBlock from '../components/CtaBlock.astro';

const waHref = 'https://wa.me/524422184424';

// Datos REALES extraídos de simacademy.emergencias.com.mx/oferta-educativa/pagos
const datosBancarios = [
  { label: 'Banco', value: 'BBVA México' },
  {
    label: 'Beneficiario',
    value: 'Asesores en Emergencias y Desastres S de RL de CV',
  },
  { label: 'CLABE interbancaria', value: '012680001699097103' },
  { label: 'SWIFT (transferencias internacionales)', value: 'BCMRMXMMPYM' },
  {
    label: 'Sucursal',
    value: 'Av. 5 Febrero 2125, Jurica, 76100, Querétaro, México (Sucursal 5731)',
  },
];

// TODO Phase 7: confirmar con JM si el link real de Clip ya existe (#placeholder por ahora)
const clipUrl = '#'; // TODO Phase 7: URL real del portal de pago Clip
const facturacionEmail = 'facturacion@emergencias.com.mx'; // TODO Phase 7: confirmar email de facturación
---

<BaseLayout
  title="Información de pagos — SimAcademy"
  description="Datos bancarios, métodos de pago, comprobantes y facturación para cursos de SimAcademy."
>
  <Hero
    eyebrow="Pagos"
    title="Información de pagos"
    subtitle="Aquí encuentras los datos para pagar tu inscripción, enviar tu comprobante y solicitar tu factura."
  />

  <!-- Métodos de pago -->
  <section class="reveal py-16 sm:py-24">
    <Container>
      <h2 class="font-display text-3xl sm:text-4xl font-semibold text-ink-900 mb-3">
        Métodos de pago aceptados
      </h2>
      <p class="text-ink-700 max-w-2xl mb-10">
        Todos los montos están en pesos mexicanos (MXN). Si necesitas otra
        forma de pago, escríbenos por WhatsApp.
      </p>

      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" role="list">
        <li class="bg-surface rounded-[var(--r-md)] border border-ink-300/30 shadow-[var(--shadow-sm)] p-6">
          <span class="inline-flex items-center justify-center w-11 h-11 rounded-full bg-brand-purple/10 text-brand-purple mb-4" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="22"/><polyline points="19 15 12 22 5 15"/></svg>
          </span>
          <h3 class="font-display text-lg font-semibold text-ink-900 mb-1">
            Transferencia nacional
          </h3>
          <p class="text-sm text-ink-700 leading-relaxed">
            SPEI a cuenta CLABE en BBVA México. Confirmación inmediata una vez
            recibido el comprobante.
          </p>
        </li>

        <li class="bg-surface rounded-[var(--r-md)] border border-ink-300/30 shadow-[var(--shadow-sm)] p-6">
          <span class="inline-flex items-center justify-center w-11 h-11 rounded-full bg-brand-purple/10 text-brand-purple mb-4" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </span>
          <h3 class="font-display text-lg font-semibold text-ink-900 mb-1">
            Transferencia internacional
          </h3>
          <p class="text-sm text-ink-700 leading-relaxed">
            Desde el extranjero usando el código SWIFT y los datos de la
            sucursal BBVA.
          </p>
        </li>

        <li class="bg-surface rounded-[var(--r-md)] border border-ink-300/30 shadow-[var(--shadow-sm)] p-6">
          <span class="inline-flex items-center justify-center w-11 h-11 rounded-full bg-brand-purple/10 text-brand-purple mb-4" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          </span>
          <h3 class="font-display text-lg font-semibold text-ink-900 mb-1">
            Tarjeta de crédito o débito
          </h3>
          <p class="text-sm text-ink-700 leading-relaxed mb-3">
            Pago en línea a través de Clip. Acepta Visa, Mastercard y AmEx.
          </p>
          <a
            href={clipUrl}
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-purple hover:underline"
          >
            Pagar con Clip
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </li>
      </ul>

      <p class="text-sm text-ink-500 mt-8">
        ¿Necesitas otro método de pago? Escríbenos por
        <a href={waHref} target="_blank" rel="noopener" class="text-brand-purple hover:underline">WhatsApp</a>
        y lo revisamos.
      </p>
    </Container>
  </section>

  <!-- Datos bancarios -->
  <section class="reveal bg-[var(--gradient-soft)] py-16 sm:py-24">
    <Container variant="narrow">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold text-ink-900 mb-3">
        Datos bancarios
      </h2>
      <p class="text-ink-700 mb-8">
        Usa estos datos para transferencias SPEI o depósitos en BBVA México.
        Da clic en <span class="font-medium">Copiar</span> para copiar el dato
        al portapapeles.
      </p>

      <div class="overflow-hidden rounded-[var(--r-md)] border border-ink-300/40 bg-surface shadow-[var(--shadow-sm)]">
        <table class="w-full text-sm" data-bank-table>
          <tbody>
            {datosBancarios.map((row, i) => (
              <tr class={i === datosBancarios.length - 1 ? '' : 'border-b border-ink-300/30'}>
                <th
                  scope="row"
                  class="text-left align-top px-4 sm:px-6 py-4 font-medium text-ink-700 w-2/5 sm:w-1/3"
                >
                  {row.label}
                </th>
                <td class="px-4 sm:px-6 py-4 text-ink-900">
                  <div class="flex items-start justify-between gap-3">
                    <span class="break-all" data-copy-value>{row.value}</span>
                    <button
                      type="button"
                      data-copy-btn
                      class="flex-shrink-0 inline-flex items-center gap-1 text-xs font-semibold text-brand-purple hover:underline focus:outline-none focus:ring-2 focus:ring-brand-purple/30 rounded px-1.5 py-0.5"
                      aria-label={`Copiar ${row.label}`}
                    >
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                      <span data-copy-label>Copiar</span>
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="text-xs text-ink-500 mt-4">
        Beneficiario y datos provistos por Asesores en Emergencias y Desastres
        S de RL de CV, matriz de SimAcademy.
      </p>
    </Container>
  </section>

  <!-- Comprobante -->
  <section class="reveal py-16 sm:py-24">
    <Container variant="narrow">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold text-ink-900 mb-3">
        Comprobante y confirmación
      </h2>
      <p class="text-ink-700 mb-6">
        Una vez realizado el pago, envíanos tu comprobante para confirmar tu
        lugar en el curso.
      </p>
      <ol class="space-y-4 text-ink-700" role="list">
        <li class="flex gap-4">
          <span class="flex-shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full bg-brand-purple text-white text-sm font-semibold" aria-hidden="true">1</span>
          <div>
            <p class="leading-relaxed">
              Realiza la transferencia o pago en línea por el monto exacto del
              curso.
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="flex-shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full bg-brand-purple text-white text-sm font-semibold" aria-hidden="true">2</span>
          <div>
            <p class="leading-relaxed">
              Envía tu comprobante (PDF o captura) por
              <a href={waHref} target="_blank" rel="noopener" class="text-brand-purple hover:underline font-medium">WhatsApp</a>
              indicando tu nombre completo y el curso al que te inscribes.
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="flex-shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-full bg-brand-purple text-white text-sm font-semibold" aria-hidden="true">3</span>
          <div>
            <p class="leading-relaxed">
              Recibirás confirmación de inscripción y, si aplica, instrucciones
              para acceder a la plataforma Moodle del curso.
            </p>
          </div>
        </li>
      </ol>
    </Container>
  </section>

  <!-- Facturación -->
  <section class="reveal bg-[var(--gradient-soft)] py-16 sm:py-24">
    <Container variant="narrow">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold text-ink-900 mb-3">
        Facturación
      </h2>
      <p class="text-ink-700 mb-6">
        Emitimos factura electrónica (CFDI 4.0). Para solicitarla, envía los
        siguientes datos junto con tu comprobante de pago.
      </p>

      <div class="bg-surface rounded-[var(--r-md)] border border-ink-300/30 shadow-[var(--shadow-sm)] p-6 sm:p-8">
        <h3 class="font-display text-lg font-semibold text-ink-900 mb-4">
          Datos que necesitamos de ti
        </h3>
        <ul class="space-y-2 text-sm text-ink-700 list-disc pl-5">
          <li>RFC con homoclave</li>
          <li>Razón social exacta (como aparece en tu constancia de situación fiscal)</li>
          <li>Código postal del domicilio fiscal</li>
          <li>Régimen fiscal</li>
          <li>Uso de CFDI (G03 — Gastos en general por default)</li>
          <li>Correo electrónico para recibir el XML y PDF</li>
        </ul>

        <div class="mt-6 pt-6 border-t border-ink-300/30 text-sm text-ink-700 space-y-1">
          <p>
            <span class="font-medium">Emisor:</span>
            Asesores en Emergencias y Desastres S de RL de CV
          </p>
          <p>
            <span class="font-medium">RFC emisor:</span>
            AED010917GKA
          </p>
          <p>
            <span class="font-medium">Domicilio fiscal:</span>
            Paseo Jurica 105-29, Jurica, Querétaro, 76100
          </p>
          <p>
            <span class="font-medium">Solicitudes:</span>
            <a href={`mailto:${facturacionEmail}`} class="text-brand-purple hover:underline">{facturacionEmail}</a>
          </p>
        </div>
      </div>

      <p class="text-xs text-ink-500 mt-4">
        Las facturas se emiten en el mismo mes del pago. Después del cierre
        mensual no es posible refacturar.
      </p>
    </Container>
  </section>

  <CtaBlock
    variant="purple"
    title="¿Dudas con tu pago?"
    description="Escríbenos por WhatsApp y te ayudamos a confirmar tu inscripción paso a paso."
    ctaLabel="Hablar por WhatsApp"
    ctaHref={waHref}
  />

  <script>
    function initCopyButtons() {
      const buttons = document.querySelectorAll<HTMLButtonElement>(
        '[data-bank-table] [data-copy-btn]'
      );
      buttons.forEach((btn) => {
        if ((btn as any).__bound) return;
        (btn as any).__bound = true;
        btn.addEventListener('click', async () => {
          const cell = btn.closest('td');
          const valueEl = cell?.querySelector<HTMLElement>('[data-copy-value]');
          const labelEl = btn.querySelector<HTMLElement>('[data-copy-label]');
          const value = valueEl?.textContent?.trim() ?? '';
          if (!value) return;
          try {
            await navigator.clipboard.writeText(value);
            if (labelEl) {
              const prev = labelEl.textContent;
              labelEl.textContent = '¡Copiado!';
              setTimeout(() => {
                if (labelEl) labelEl.textContent = prev ?? 'Copiar';
              }, 1600);
            }
          } catch (_err) {
            if (labelEl) labelEl.textContent = 'Error';
          }
        });
      });
    }
    initCopyButtons();
    document.addEventListener('astro:page-load', initCopyButtons);
  </script>
</BaseLayout>
