---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Hero from '../components/Hero.astro';
import CtaBlock from '../components/CtaBlock.astro';

const waNumber = '+52 442 218 4424';
const waHref = 'https://wa.me/524422184424';
const email = 'hola@simacademy.lat'; // TODO Phase 7: confirmar email definitivo de contacto con JM
const address = 'Paseo Jurica 105-29, Querétaro, México';
const mapsHref =
  'https://www.google.com/maps/search/?api=1&query=' +
  encodeURIComponent(address);
const horario = 'Lun–Vie 9:00 a 18:00 (CDMX)';

// TODO Phase 7: reemplazar PLACEHOLDER_FORM_ID con el ID real de Formspree
const formspreeAction = 'https://formspree.io/f/PLACEHOLDER_FORM_ID';
---

<BaseLayout
  title="Contacto — SimAcademy"
  description="Habla con SimAcademy. Envía tu duda por formulario, WhatsApp o correo y diseñamos juntos el siguiente paso de tu formación."
>
  <Hero
    eyebrow="Contacto"
    title="Contáctanos"
    subtitle="Estamos aquí para resolver tus dudas y diseñar juntos el siguiente paso de tu formación."
  />

  <section class="reveal py-16 sm:py-24">
    <Container>
      <div class="grid gap-10 lg:grid-cols-5 lg:gap-12 items-start">
        <!-- Formulario -->
        <div class="lg:col-span-3">
          <h2 class="font-display text-2xl sm:text-3xl font-semibold text-ink-900 mb-2">
            Escríbenos
          </h2>
          <p class="text-ink-700 mb-6">
            Llena el formulario y te respondemos en horario hábil. Si prefieres
            algo más directo, WhatsApp suele ser lo más rápido.
          </p>

          <form
            id="contact-form"
            action={formspreeAction}
            method="POST"
            data-form-status="idle"
            class="space-y-4 bg-surface rounded-[var(--r-md)] border border-ink-300/30 shadow-[var(--shadow-sm)] p-6 sm:p-8"
            novalidate
          >
            <div>
              <label
                for="contact-name"
                class="block text-sm font-medium text-ink-900 mb-1.5"
              >
                Nombre <span class="text-brand-purple" aria-hidden="true">*</span>
              </label>
              <input
                id="contact-name"
                name="name"
                type="text"
                autocomplete="name"
                required
                aria-required="true"
                class="w-full px-3 py-2.5 rounded-lg border border-ink-300 bg-paper text-ink-900 placeholder:text-ink-500 focus:outline-none focus:border-brand-purple focus:ring-2 focus:ring-brand-purple/20"
                placeholder="Tu nombre completo"
              />
            </div>

            <div>
              <label
                for="contact-email"
                class="block text-sm font-medium text-ink-900 mb-1.5"
              >
                Correo electrónico <span class="text-brand-purple" aria-hidden="true">*</span>
              </label>
              <input
                id="contact-email"
                name="email"
                type="email"
                autocomplete="email"
                required
                aria-required="true"
                class="w-full px-3 py-2.5 rounded-lg border border-ink-300 bg-paper text-ink-900 placeholder:text-ink-500 focus:outline-none focus:border-brand-purple focus:ring-2 focus:ring-brand-purple/20"
                placeholder="tu@correo.com"
              />
            </div>

            <div>
              <label
                for="contact-phone"
                class="block text-sm font-medium text-ink-900 mb-1.5"
              >
                Teléfono <span class="text-ink-500 text-xs font-normal">(opcional)</span>
              </label>
              <input
                id="contact-phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                class="w-full px-3 py-2.5 rounded-lg border border-ink-300 bg-paper text-ink-900 placeholder:text-ink-500 focus:outline-none focus:border-brand-purple focus:ring-2 focus:ring-brand-purple/20"
                placeholder="+52 442 000 0000"
              />
            </div>

            <div>
              <label
                for="contact-message"
                class="block text-sm font-medium text-ink-900 mb-1.5"
              >
                Mensaje <span class="text-brand-purple" aria-hidden="true">*</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                rows="5"
                required
                aria-required="true"
                class="w-full px-3 py-2.5 rounded-lg border border-ink-300 bg-paper text-ink-900 placeholder:text-ink-500 focus:outline-none focus:border-brand-purple focus:ring-2 focus:ring-brand-purple/20 resize-y"
                placeholder="Cuéntanos qué necesitas, en qué curso estás interesado o qué proyecto quieres explorar."
              ></textarea>
            </div>

            <div class="flex items-start gap-2.5">
              <input
                id="contact-privacy"
                name="privacy"
                type="checkbox"
                required
                aria-required="true"
                class="mt-1 h-4 w-4 rounded border-ink-300 text-brand-purple focus:ring-brand-purple/30"
              />
              <label
                for="contact-privacy"
                class="text-sm text-ink-700 leading-relaxed"
              >
                Acepto la política de privacidad y el tratamiento de mis datos
                para responder a este mensaje.
              </label>
            </div>

            <!-- Honeypot anti-spam -->
            <input
              type="text"
              name="_gotcha"
              tabindex="-1"
              autocomplete="off"
              class="hidden"
              aria-hidden="true"
            />

            <div class="flex flex-col sm:flex-row sm:items-center gap-3 pt-1">
              <button
                type="submit"
                class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full bg-brand-purple text-white text-sm font-semibold shadow-[var(--shadow-brand)] hover:bg-brand-purple-dark transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
              >
                <span data-status-label>Enviar mensaje</span>
              </button>
              <p
                id="contact-form-msg"
                class="text-sm text-ink-700"
                role="status"
                aria-live="polite"
              ></p>
            </div>
          </form>
        </div>

        <!-- Info -->
        <aside class="lg:col-span-2 space-y-4">
          <div class="bg-surface rounded-[var(--r-md)] border border-ink-300/30 shadow-[var(--shadow-sm)] p-6">
            <div class="flex items-start gap-3">
              <span class="flex-shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-full bg-brand-green/15 text-brand-green" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              </span>
              <div>
                <h3 class="font-display text-lg font-semibold text-ink-900">WhatsApp</h3>
                <p class="text-sm text-ink-700 mt-0.5">{waNumber}</p>
                <a
                  href={waHref}
                  target="_blank"
                  rel="noopener"
                  class="mt-3 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-green text-white text-sm font-semibold hover:bg-brand-green-dark transition-colors"
                >
                  Hablar por WhatsApp
                </a>
              </div>
            </div>
          </div>

          <div class="bg-surface rounded-[var(--r-md)] border border-ink-300/30 shadow-[var(--shadow-sm)] p-6">
            <div class="flex items-start gap-3">
              <span class="flex-shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-full bg-brand-purple/10 text-brand-purple" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </span>
              <div>
                <h3 class="font-display text-lg font-semibold text-ink-900">Correo</h3>
                <a
                  href={`mailto:${email}`}
                  class="text-sm text-brand-purple hover:underline break-all"
                >
                  {email}
                </a>
              </div>
            </div>
          </div>

          <div class="bg-surface rounded-[var(--r-md)] border border-ink-300/30 shadow-[var(--shadow-sm)] p-6">
            <div class="flex items-start gap-3">
              <span class="flex-shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-full bg-brand-purple/10 text-brand-purple" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <div>
                <h3 class="font-display text-lg font-semibold text-ink-900">Oficina</h3>
                <p class="text-sm text-ink-700 mt-0.5">{address}</p>
                <a
                  href={mapsHref}
                  target="_blank"
                  rel="noopener"
                  class="mt-2 inline-block text-sm text-brand-purple hover:underline"
                >
                  Ver en Google Maps
                </a>
              </div>
            </div>
          </div>

          <div class="bg-surface rounded-[var(--r-md)] border border-ink-300/30 shadow-[var(--shadow-sm)] p-6">
            <div class="flex items-start gap-3">
              <span class="flex-shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-full bg-brand-purple/10 text-brand-purple" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </span>
              <div>
                <h3 class="font-display text-lg font-semibold text-ink-900">Horario</h3>
                <p class="text-sm text-ink-700 mt-0.5">{horario}</p>
                <!-- TODO Phase 7: confirmar horario real de atención con JM -->
              </div>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  <CtaBlock
    variant="purple"
    title="¿Listo para dar el siguiente paso?"
    description="Explora nuestra oferta educativa o agenda una llamada para diseñar un programa a la medida de tu institución."
    ctaLabel="Ver oferta educativa"
    ctaHref="/oferta-educativa"
  />

  <script>
    function initContactForm() {
      const form = document.getElementById('contact-form') as HTMLFormElement | null;
      if (!form || (form as any).__bound) return;
      const msg = document.getElementById('contact-form-msg');
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const label = form.querySelector<HTMLElement>('[data-status-label]');

      const setStatus = (state: string, text: string) => {
        form.setAttribute('data-form-status', state);
        if (msg) msg.textContent = text;
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!form.reportValidity()) return;
        setStatus('sending', 'Enviando…');
        if (btn) btn.disabled = true;
        if (label) label.textContent = 'Enviando…';
        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });
          if (res.ok) {
            setStatus('ok', 'Recibimos tu mensaje. Te respondemos en breve.');
            form.reset();
            if (label) label.textContent = 'Enviado';
          } else {
            setStatus(
              'error',
              'No pudimos enviar el mensaje. Intenta por WhatsApp.'
            );
            if (label) label.textContent = 'Enviar mensaje';
            if (btn) btn.disabled = false;
          }
        } catch (_err) {
          setStatus(
            'error',
            'No pudimos enviar el mensaje. Intenta por WhatsApp.'
          );
          if (label) label.textContent = 'Enviar mensaje';
          if (btn) btn.disabled = false;
        }
      });
      (form as any).__bound = true;
    }
    initContactForm();
    document.addEventListener('astro:page-load', initContactForm);
  </script>
</BaseLayout>
