---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import CtaBlock from '../components/CtaBlock.astro';

const valores = [
  {
    title: 'Rigor clínico',
    body:
      'Diseñamos cada escenario con base en evidencia, guías vigentes y la realidad de la práctica clínica en Latinoamérica.',
    icon: 'stethoscope',
  },
  {
    title: 'Criterio',
    body:
      'Formamos profesionales que piensan, no que repiten. El debriefing estructurado entrena el juicio, no solo el procedimiento.',
    icon: 'brain',
  },
  {
    title: 'Hospitalidad pedagógica',
    body:
      'La seguridad psicológica es condición, no cortesía. Aprender lo difícil exige un lugar donde equivocarse sea parte del proceso.',
    icon: 'heart',
  },
  {
    title: 'Evidencia',
    body:
      'Aplicamos lo que la ciencia de la educación en simulación ha demostrado que funciona, y revisamos lo que no.',
    icon: 'flask',
  },
];

const B = import.meta.env.BASE_URL.replace(/\/$/, '');

const hitos = [
  {
    year: '2001',
    title: 'Fundación',
    body:
      'Nace Asesores en Emergencias y Desastres, casa matriz de SimAcademy, dedicada a la formación de profesionales de la salud.',
  },
  {
    year: '2006',
    title: 'Centro de entrenamiento AHA',
    body:
      'Nos certificamos como Centro Internacional de Entrenamiento de la American Heart Association.',
  },
  {
    year: '2012',
    title: 'Nace SimMx',
    body:
      'Lanzamos SimMx como brazo educativo enfocado exclusivamente en simulación clínica.',
  },
  {
    year: '2015',
    title: 'SimAcademy — marca registrada',
    body:
      'SimMx evoluciona a SimAcademy, marca registrada en México y Europa.',
  },
  {
    year: '2017',
    title: 'Ciudad Cardio Protegida',
    body:
      'Asesores en Emergencias participa en el programa de Ciudad Cardio Protegida en Querétaro, México.',
  },
  {
    year: '2021',
    title: 'Socios de EuSim',
    body:
      'Nos integramos como partners oficiales de la red EuSim, comunidad internacional de centros de simulación.',
  },
];

const impacto = [
  {
    value: '100,000+',
    label: 'Personas certificadas con la American Heart Association',
  },
  {
    value: '300+',
    label: 'Educadores en simulación formados con EuSim',
  },
  {
    value: '600+',
    label: 'Participantes en Introducción a la Simulación Clínica',
  },
  {
    value: '8+',
    label: 'Países en LATAM y Europa donde hemos colaborado',
  },
];

const team = [
  {
    name: 'Juan Manuel Fraga',
    role: 'Director de SimAcademy',
    bio: '',
    photo: `${B}/team/juan-manuel-fraga.jpg`,
  },
  {
    name: 'José Luis Pérez Espino',
    role: 'Director de Asesores en Emergencias y Desastres',
    bio: '',
    photo: `${B}/team/jose-luis-perez-espino.jpg`,
  },
  {
    name: 'Tanya Loizaga Melhado',
    role: 'Encargada de oficina',
    bio: '',
    photo: `${B}/team/tanya-loizaga-melhado.jpg`,
  },
];
---

<BaseLayout
  title="Sobre SimAcademy — Quiénes somos"
  description="SimAcademy es una academia de simulación clínica en Latinoamérica. Conoce nuestra historia, equipo y filosofía educativa."
>
  <Hero
    eyebrow="Sobre nosotros"
    title="Sobre SimAcademy"
    subtitle="Somos una academia dedicada a la educación basada en simulación clínica, formando profesionales de la salud en Latinoamérica con estándares internacionales."
    image={{
      src: `${B}/photos/sobre-grupo-eusim.jpg`,
      alt: 'Equipo y participantes de SimAcademy en una sesión de curso EuSim — formación con estándares internacionales.',
    }}
  />

  <section class="reveal py-20 sm:py-28">
    <Container variant="narrow">
      <SectionTitle
        eyebrow="Nuestra historia"
        title="De SimMx a SimAcademy."
      />
      <div class="mt-8 space-y-5 text-lg text-ink-700 leading-relaxed">
        <p>
          SimAcademy, antes SimMx, es una marca registrada y forma parte de
          Asesores en Emergencias y Desastres, casa matriz que en septiembre
          de 2026 cumple <strong>25 años</strong> de operación. Nos
          especializamos en cursos sobre educación, pedagogía, simulación
          clínica y estrategias innovadoras para la formación de
          profesionales de la salud.
        </p>
        <p>
          Hemos colaborado con instituciones en Latinoamérica, Europa y Asia
          en la capacitación, diseño y desarrollo de programas educativos.
          Contamos con una oferta de cursos establecida, pero también
          diseñamos programas hechos a la medida para instituciones
          educativas.
        </p>
        <p>
          Somos parte de la red EuSim, una comunidad internacional de centros
          de simulación con un marco pedagógico común, lo que nos permite
          ofrecer formación con estándares globales en español, desde y para
          LATAM.
        </p>
      </div>
    </Container>
  </section>

  <section class="reveal py-20 sm:py-28 bg-surface">
    <Container variant="narrow">
      <SectionTitle
        eyebrow="Línea de tiempo"
        title="25 años, seis hitos."
        align="center"
        class="mx-auto mb-12"
      />
      <ol class="relative border-l-2 border-brand-purple/20 ml-3 space-y-10" role="list">
        {hitos.map((h) => (
          <li class="relative pl-8">
            <span
              class="absolute -left-[11px] top-1.5 inline-flex items-center justify-center w-5 h-5 rounded-full bg-brand-purple ring-4 ring-surface"
              aria-hidden="true"
            ></span>
            <p class="font-display text-2xl font-semibold text-brand-purple leading-none">
              {h.year}
            </p>
            <h3 class="font-display text-lg font-semibold text-ink-900 mt-1 mb-1">
              {h.title}
            </h3>
            <p class="text-sm text-ink-700 leading-relaxed">{h.body}</p>
          </li>
        ))}
      </ol>
    </Container>
  </section>

  <section class="reveal bg-[var(--gradient-soft)] py-20 sm:py-28">
    <Container>
      <SectionTitle
        eyebrow="Impacto"
        title="Lo que nos respalda."
        subtitle="Cifras acumuladas de Asesores en Emergencias y SimAcademy a lo largo de 25 años."
        align="center"
        class="mx-auto mb-12"
      />
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-4xl mx-auto" role="list">
        {impacto.map((i) => (
          <li class="bg-surface rounded-[var(--r-md)] border border-ink-300/30 shadow-[var(--shadow-sm)] p-6 flex flex-col items-start gap-2">
            <p class="font-display text-4xl sm:text-5xl font-semibold text-brand-purple tabular-nums">
              {i.value}
            </p>
            <p class="text-sm text-ink-700 leading-relaxed">{i.label}</p>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <section class="reveal bg-surface py-20 sm:py-28">
    <Container>
      <SectionTitle
        eyebrow="Filosofía"
        title="Lo que nos guía."
        subtitle="Cuatro principios que no negociamos en ningún curso, ningún debriefing, ninguna conversación con un participante."
        align="center"
        class="mx-auto mb-12"
      />
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-6" role="list">
        {valores.map((v) => (
          <li class="bg-surface rounded-[var(--r-md)] border border-ink-300/30 shadow-[var(--shadow-sm)] p-6 flex gap-4 items-start">
            <span
              class="flex-shrink-0 inline-flex items-center justify-center w-11 h-11 rounded-full bg-brand-purple/10 text-brand-purple"
              aria-hidden="true"
            >
              {v.icon === 'stethoscope' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4"/><circle cx="20" cy="10" r="2"/></svg>
              )}
              {v.icon === 'brain' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/></svg>
              )}
              {v.icon === 'heart' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              )}
              {v.icon === 'flask' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2v7.31"/><path d="M14 9.3V1.99"/><path d="M8.5 2h7"/><path d="M14 9.3a6.5 6.5 0 1 1-4 0"/><path d="M5.52 16h12.96"/></svg>
              )}
            </span>
            <div>
              <h3 class="font-display text-xl font-semibold text-ink-900 mb-1">
                {v.title}
              </h3>
              <p class="text-sm text-ink-700 leading-relaxed">{v.body}</p>
            </div>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <section class="reveal py-20 sm:py-28">
    <Container>
      <SectionTitle
        eyebrow="Equipo"
        title="Quiénes están detrás."
        subtitle="Dirección y oficina de SimAcademy. Próximamente publicaremos también al faculty de instructores."
        align="center"
        class="mx-auto mb-12"
      />
      <ul
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto"
        role="list"
      >
        {team.map((p) => (
          <li class="bg-surface rounded-[var(--r-md)] border border-ink-300/30 shadow-[var(--shadow-sm)] p-6 text-center flex flex-col items-center gap-3">
            <img
              src={p.photo}
              alt={`Foto de ${p.name}`}
              class="w-28 h-28 rounded-full object-cover ring-2 ring-brand-purple/20 bg-ink-300/20"
              loading="lazy"
              width="112"
              height="112"
              onerror="this.style.visibility='hidden'"
            />
            <div>
              <h3 class="font-display text-lg font-semibold text-ink-900">
                {p.name}
              </h3>
              <p class="text-sm font-medium text-brand-purple">{p.role}</p>
            </div>
            {p.bio && (
              <p class="text-sm text-ink-700 leading-relaxed">{p.bio}</p>
            )}
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <CtaBlock
    variant="purple"
    title="¿Quieres trabajar con nosotros?"
    description="Hablemos de tu institución, tu programa o tu proyecto educativo. Escríbenos por WhatsApp."
    ctaLabel="Hablar con SimAcademy"
    ctaHref="https://wa.me/524422184424"
  />
</BaseLayout>
