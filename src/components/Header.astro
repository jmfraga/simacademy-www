---
const B = import.meta.env.BASE_URL.replace(/\/$/, ''); // '' o '/simacademy-www'
const navLinks = [
  { href: `${B}/`, label: 'Inicio' },
  { href: `${B}/sobre`, label: 'Sobre' },
  { href: `${B}/oferta-educativa`, label: 'Oferta educativa' },
  { href: `${B}/recursos`, label: 'Recursos' },
  { href: `${B}/comunidad`, label: 'Comunidad' },
  { href: `${B}/contacto`, label: 'Contacto' },
];
const waHref = 'https://wa.me/524422184424';

const pathname = Astro.url.pathname;
const homePath = `${B}/`;
const isActive = (href: string) => {
  if (href === homePath) return pathname === homePath || pathname === B || pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
};
---

<header
  id="site-header"
  data-scrolled="false"
  class="sticky top-0 z-50 transition-[background-color,box-shadow,backdrop-filter] duration-300 bg-paper/70 backdrop-blur-md border-b border-transparent data-[scrolled=true]:bg-paper/95 data-[scrolled=true]:shadow-sm data-[scrolled=true]:border-ink-300/40"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
    <a href={`${B}/`} class="flex items-center gap-2" aria-label="SimAcademy inicio" transition:name="site-logo">
      <img src={`${B}/logo.png`} alt="" class="h-9 w-auto" width="36" height="36" />
      <span class="font-display text-lg font-semibold text-ink-900 hidden sm:inline">
        SimAcademy
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Primaria">
      {navLinks.map((l) => {
        const active = isActive(l.href);
        return (
          <a
            href={l.href}
            aria-current={active ? 'page' : undefined}
            class:list={[
              'relative px-3 py-2 text-sm font-medium transition-colors',
              active ? 'text-brand-purple' : 'text-ink-700 hover:text-brand-purple',
            ]}
          >
            {l.label}
            {active && (
              <span class="absolute left-3 right-3 -bottom-0.5 h-0.5 rounded-full bg-brand-purple" aria-hidden="true"></span>
            )}
          </a>
        );
      })}
      <a
        href={waHref}
        target="_blank"
        rel="noopener"
        class="ml-3 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-green text-white text-sm font-semibold shadow-sm hover:bg-brand-green-dark transition-colors"
      >
        WhatsApp
      </a>
    </nav>

    <button
      id="nav-toggle"
      type="button"
      class="md:hidden relative z-[60] inline-flex items-center justify-center p-2 rounded-md text-ink-700 hover:bg-ink-300/20"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <svg data-nav-icon="open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
      <svg data-nav-icon="close" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile full-screen menu: <dialog> nativo se renderiza en el top layer
       del browser, garantizando que aparezca encima de cualquier stacking
       context y de cualquier widget de terceros (Clientify, etc.). -->
  <dialog
    id="mobile-nav"
    class="md:hidden m-0 w-full max-w-none h-full max-h-none p-0 bg-paper text-ink-900 backdrop:bg-ink-900/40"
    aria-label="Menú principal"
  >
    <div class="flex flex-col h-full">
      <!-- Mini header dentro del dialog: logo + botón cerrar -->
      <div class="flex items-center justify-between h-16 px-4 sm:px-6 border-b border-ink-300/30 bg-paper">
        <a href={`${B}/`} class="flex items-center gap-2" aria-label="SimAcademy inicio">
          <img src={`${B}/logo.png`} alt="" class="h-9 w-auto" width="36" height="36" />
          <span class="font-display text-lg font-semibold text-ink-900">SimAcademy</span>
        </a>
        <button
          id="nav-close"
          type="button"
          class="inline-flex items-center justify-center p-2 rounded-md text-ink-700 hover:bg-ink-300/20"
          aria-label="Cerrar menú"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

    <nav class="flex-1 overflow-y-auto px-6 py-6 flex flex-col gap-1" aria-label="Móvil">
      {navLinks.map((l) => {
        const active = isActive(l.href);
        return (
          <a
            href={l.href}
            aria-current={active ? 'page' : undefined}
            class:list={[
              'px-4 py-3.5 rounded-xl text-base font-display font-medium transition-colors border-b border-ink-300/30',
              active ? 'text-brand-purple' : 'text-ink-900 hover:text-brand-purple',
            ]}
          >
            {l.label}
          </a>
        );
      })}
      <a
        href={waHref}
        target="_blank"
        rel="noopener"
        class="mt-6 inline-flex items-center justify-center gap-2 px-5 py-3.5 rounded-full bg-brand-green text-white text-base font-semibold"
      >
        WhatsApp
      </a>
    </nav>
    </div>
  </dialog>
</header>

<script>
  // Sticky scroll style + mobile menu via <dialog>. El elemento <dialog> con
  // showModal() se renderiza en el top layer del browser — garantiza estar
  // arriba de cualquier widget de terceros y resuelve issues de stacking
  // context heredados de ancestros con transform/filter.
  function initHeader() {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('nav-toggle');
    const panel = document.getElementById('mobile-nav') as HTMLDialogElement | null;
    const closeBtn = document.getElementById('nav-close');
    if (!header || !toggle || !panel) return;

    const iconOpen = toggle.querySelector<HTMLElement>('[data-nav-icon="open"]');
    const iconClose = toggle.querySelector<HTMLElement>('[data-nav-icon="close"]');

    const openMenu = () => {
      if (typeof panel.showModal === 'function' && !panel.open) {
        panel.showModal();
      }
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Cerrar menú');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
    };

    const closeMenu = () => {
      if (typeof panel.close === 'function' && panel.open) {
        panel.close();
      }
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Abrir menú');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    };

    // Sticky scroll style del header
    if (!(header as any).__scrollBound) {
      const onScroll = () => {
        header.dataset.scrolled = window.scrollY > 8 ? 'true' : 'false';
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
      (header as any).__scrollBound = true;
    }

    if (!(toggle as any).__bound) {
      toggle.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (panel.open) closeMenu();
        else openMenu();
      });
      closeBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        closeMenu();
      });
      // Click en un enlace de navegación: cerrar antes de navegar
      panel.addEventListener('click', (e) => {
        const t = e.target as HTMLElement;
        const a = t.closest('a');
        if (a && a.id !== 'nav-close') closeMenu();
      });
      // Click sobre el ::backdrop (fuera del contenido) cierra
      panel.addEventListener('click', (e) => {
        if (e.target === panel) closeMenu();
      });
      // El <dialog> dispara 'close' al hacer Escape — sincronizamos icono
      panel.addEventListener('close', () => {
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Abrir menú');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
      });
      (toggle as any).__bound = true;
    }

    // Asegurar estado cerrado al entrar a la página
    closeMenu();
  }

  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>
