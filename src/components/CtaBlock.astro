---
import Container from './Container.astro';

interface Props {
  title: string;
  description?: string;
  ctaLabel: string;
  ctaHref: string;
  variant?: 'purple' | 'green';
}

const {
  title,
  description,
  ctaLabel,
  ctaHref,
  variant = 'purple',
} = Astro.props;

const bg =
  variant === 'green' ? 'bg-brand-green' : 'bg-brand-purple';
const btnText =
  variant === 'green' ? 'text-brand-green' : 'text-brand-purple';
---

<section class={`${bg} text-white`}>
  <Container class="py-16 sm:py-20 text-center">
    <div class="max-w-2xl mx-auto flex flex-col items-center gap-5">
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold leading-tight">
        {title}
      </h2>
      {description && (
        <p class="text-lg text-white/90 leading-relaxed">
          {description}
        </p>
      )}
      <a
        href={ctaHref}
        class={`mt-2 inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-white ${btnText} text-sm font-semibold shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all`}
      >
        {ctaLabel}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </Container>
</section>
